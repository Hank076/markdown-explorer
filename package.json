{
  "name": "markdown-explorer",
  "version": "1.0.0",
  "description": "A browser-based Markdown viewer with folder tree, multi-tab preview, Mermaid diagrams, and syntax highlighting — no build step required.",
  "author": "Hank",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "markdown",
    "preview",
    "viewer",
    "mermaid",
    "highlight",
    "file-system-access-api",
    "no-build"
  ],
  "scripts": {
    "start": "npx serve .",
    "test": "node --test tests/workspace/*.test.mjs"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "marked": "^17.0.5",
    "mathjax-full": "^3.2.1",
    "mermaid": "^11.13.0",
    "prismjs": "^1.30.0"
  }
}
